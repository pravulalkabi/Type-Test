rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Validator for User
    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() < 500)) &&
             data.createdAt is timestamp;
    }

    // Validator for Score
    function isValidScore(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() < 100 &&
             data.wpm is number && data.wpm >= 0 && data.wpm < 500 &&
             data.accuracy is number && data.accuracy >= 0 && data.accuracy <= 100 &&
             data.time is number && data.time > 0 &&
             data.createdAt is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /scores/{scoreId} {
      allow read: if true; // Leaderboard is public
      allow create: if isAuthenticated() && isValidScore(request.resource.data);
      allow update, delete: if false; // Scores are immutable
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
